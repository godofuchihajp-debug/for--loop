// Version 1
public class PowerSeries {
    public static void main(String[] args) {
        int x = 2, n = 5, sum = 0, term = 1;
        for(int i = 1; i <= n; i++) { term *= x; sum += term; }
        System.out.println("Sum: " + sum);
    }
}
